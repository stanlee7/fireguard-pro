# FireGuard Pro — 알림톡 API 환경 변수
# 아래 값들을 실제 키 값으로 교체하세요

# ── Solapi (메인) ──
SOLAPI_API_KEY=your_solapi_api_key
SOLAPI_API_SECRET=your_solapi_api_secret
SOLAPI_PFID=KA01PF_your_kakao_channel_id
SOLAPI_TEMPLATE_INSPECTION=TKxxxxxx_점검완료_템플릿_코드
SOLAPI_TEMPLATE_LOW_STOCK=TKyyyyyy_부품교체_템플릿_코드

# ── NHN Cloud (대안) ──
NHN_APP_KEY=your_nhn_app_key
NHN_SECRET_KEY=your_nhn_secret_key
NHN_SENDER_KEY=your_nhn_sender_key

# ── 서버 ──
PORT=3001
